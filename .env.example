# Google OAuth
# Crear credenciales en https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3000/api/auth (dev) / https://tu-dominio.com/api/auth (prod)
GOOGLE_CLIENT_ID=tu_client_id
GOOGLE_CLIENT_SECRET=tu_client_secret

# Emails permitidos (separados por coma)
ALLOWED_EMAILS=email1@gmail.com,email2@gmail.com

# Secret para firmar JWT de sesión
SESSION_SECRET=genera_un_secret_random

# Fudo API - Autenticación centralizada en https://auth.fu.do/api
# Cada sucursal tiene su propio apiKey + apiSecret
# Pedilo a soporte@fu.do indicando el nombre de cuenta y usuario

# Fudo - Palermo
FUDO_PALERMO_API_KEY=tu_api_key_palermo
FUDO_PALERMO_API_SECRET=tu_api_secret_palermo

# Fudo - Belgrano
FUDO_BELGRANO_API_KEY=tu_api_key_belgrano
FUDO_BELGRANO_API_SECRET=tu_api_secret_belgrano

# Fudo - Puerto Madero
FUDO_PUERTO_API_KEY=tu_api_key_puerto
FUDO_PUERTO_API_SECRET=tu_api_secret_puerto
