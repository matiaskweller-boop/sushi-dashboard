# Fudo API - Autenticación centralizada en https://auth.fu.do/api
# Cada sucursal tiene su propio apiKey + apiSecret
# Pedilo a soporte@fu.do indicando el nombre de cuenta y usuario

# Fudo - Palermo
FUDO_PALERMO_API_KEY=tu_api_key_palermo
FUDO_PALERMO_API_SECRET=tu_api_secret_palermo

# Fudo - Belgrano
FUDO_BELGRANO_API_KEY=tu_api_key_belgrano
FUDO_BELGRANO_API_SECRET=tu_api_secret_belgrano

# Fudo - Puerto Madero
FUDO_PUERTO_API_KEY=tu_api_key_puerto
